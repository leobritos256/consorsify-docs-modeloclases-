<style>
#cd5{width:100%;overflow-x:auto}
#cd5 svg{min-width:1300px}
</style>
<h2 class="sr-only">Diagrama de clases definitivo de Consorsify con 14 entidades, atributos y métodos completos.</h2>
<div id="cd5"></div>
<script type="module">
import mermaid from 'https://esm.sh/mermaid@11/dist/mermaid.esm.min.mjs';
const dark = matchMedia('(prefers-color-scheme: dark)').matches;
await document.fonts.ready;
mermaid.initialize({
  startOnLoad: false,
  theme: 'base',
  fontFamily: '"Anthropic Sans", sans-serif',
  themeVariables: {
    darkMode: dark,
    fontSize: '11px',
    fontFamily: '"Anthropic Sans", sans-serif',
    lineColor: dark ? '#9c9a92' : '#73726c',
    textColor: dark ? '#c2c0b6' : '#3d3d3a',
    primaryColor: dark ? '#3C3489' : '#EEEDFE',
    primaryTextColor: dark ? '#CECBF6' : '#26215C',
    primaryBorderColor: dark ? '#7F77DD' : '#534AB7',
    secondaryColor: dark ? '#085041' : '#E1F5EE',
    tertiaryColor: dark ? '#444441' : '#F1EFE8',
  },
});

const diagram = `classDiagram
  direction TB

  class Usuario {
    +UUID id
    +String email
    +String password
    +String nombre
    +String apellido
    +Enum rol
    +String telefono
    +String avatar
    +login(email, password)
    +register(data)
    +updateProfile(data)
    +updateNotificationPreferences(prefs)
  }

  class Notificacion {
    +UUID id
    +String titulo
    +String mensaje
    +Enum tipo
    +Boolean leida
    +String link
    +create(usuarioId, data)
    +markAsRead(id)
    +clearAll(usuarioId)
  }

  class Consorcio {
    +UUID id
    +String nombre
    +String direccion
    +Float tasaInteres
    +DateTime fechaCreacion
    +addUnit(unidadData)
    +updateInterestRate(tasa)
    +getGeneralStats(periodo)
    +calculateMonthlyExpenses(periodo)
  }

  class Unidad {
    +UUID id
    +String numero
    +String piso
    +Float coeficiente
    +calculateCurrentDebt()
    +assignOwner(usuarioId)
    +assignTenant(usuarioId)
    +getHistory()
  }

  class Comprobante {
    +UUID id
    +String descripcion
    +Float monto
    +String categoria
    +Enum tipo
    +DateTime fecha
    +createVoucher(data)
    +listByPeriod(consorcioId, periodo)
  }

  class Expensa {
    +UUID id
    +String periodo
    +Float montoTotal
    +Enum estado
    +calculatePeriodTotal(consId, periodo)
    +generateBreakdown()
  }

  class Liquidacion {
    +UUID id
    +String periodo
    +Float expensasComunes
    +Float expensasExtraordinarias
    +Float deudaAnterior
    +Float interes
    +Float total
    +Float montoPagado
    +DateTime fechaVencimiento
    +Enum estado
    +generateMass(consId, periodo, fechaVenc)
    +updateStatus()
    +calculateInterests()
  }

  class Pago {
    +UUID id
    +Float monto
    +Enum metodoPago
    +String nroRecibo
    +String adjunto
    +Enum estado
    +reportPayment(data)
    +approve(id)
    +cancel(motivo)
    +generateReceiptNumber()
  }

  class Reclamo {
    +UUID id
    +String asunto
    +String descripcion
    +Enum estado
    +Enum prioridad
    +create(data)
    +changeStatus(nuevoEstado)
    +assignPriority(nivel)
  }

  class Comentario {
    +UUID id
    +String contenido
    +UUID usuarioId
    +String nombreUsuario
    +post(reclamoId, contenido)
    +delete(id)
  }

  class Anuncio {
    +UUID id
    +String titulo
    +String contenido
    +DateTime fechaEvento
    +publish(consId, data)
  }

  class Propuesta {
    +UUID id
    +String titulo
    +String descripcion
    +Float monto
    +DateTime fechaCierre
    +Enum estado
    +registerVote(usuarioId, valor)
    +closeVoting()
    +calculateResults()
  }

  class Voto {
    +UUID id
    +Boolean valor
    +cast(usuarioId, valor)
  }

  class Presupuesto {
    +UUID id
    +String proveedor
    +String descripcion
    +Float monto
    +String adjunto
    +upload(propuestaId, data)
  }

  Consorcio "1" --> "0..*" Unidad : contiene
  Consorcio "1" --> "0..*" Comprobante : registra
  Consorcio "1" --> "0..*" Expensa : resume
  Consorcio "1" --> "0..*" Reclamo : gestiona
  Consorcio "1" --> "0..*" Anuncio : publica
  Consorcio "1" --> "0..*" Propuesta : propone

  Usuario "1" --> "0..*" Unidad : propietario/inquilino
  Usuario "1" --> "0..*" Notificacion : recibe
  Usuario "1" --> "0..*" Voto : emite
  Usuario "1" --> "0..*" Comentario : escribe

  Unidad "1" --> "0..*" Liquidacion : genera
  Unidad "1" --> "0..*" Pago : registra
  Unidad "1" --> "0..*" Reclamo : origina

  Liquidacion "1" --> "0..*" Pago : incluye

  Reclamo "1" --> "0..*" Comentario : tiene

  Propuesta "1" --> "0..*" Presupuesto : adjunta
  Propuesta "1" --> "0..*" Voto : recibe
`;

const { svg } = await mermaid.render('cd5-svg', diagram);
document.getElementById('cd5').innerHTML = svg;

document.querySelectorAll('#cd5 svg .node').forEach(node => {
  const fp = node.querySelector('path[d]');
  if (!fp) return;
  const nums = fp.getAttribute('d').match(/-?[\d.]+/g)?.map(Number);
  if (!nums || nums.length < 8) return;
  const xs=[nums[0],nums[2],nums[4],nums[6]], ys=[nums[1],nums[3],nums[5],nums[7]];
  const x=Math.min(...xs), y=Math.min(...ys), w=Math.max(...xs)-x, h=Math.max(...ys)-y;
  const rect=document.createElementNS('http://www.w3.org/2000/svg','rect');
  rect.setAttribute('x',x); rect.setAttribute('y',y);
  rect.setAttribute('width',w); rect.setAttribute('height',h); rect.setAttribute('rx','8');
  for(const a of['fill','stroke','stroke-width','class','style'])
    if(fp.hasAttribute(a)) rect.setAttribute(a,fp.getAttribute(a));
  fp.replaceWith(rect);
});
</script>
